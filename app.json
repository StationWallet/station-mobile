{
  "expo": {
    "name": "Vultisig",
    "slug": "vultisig",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/terraStation.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#1f42b4"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "scheme": "terrastation",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_PROJECT_ID",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "money.terra.station",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1f42b4"
      },
      "package": "money.terra.station",
      "versionCode": 1
    },
    "plugins": [
      "expo-secure-store",
      "expo-camera",
      "expo-local-authentication",
      "@config-plugins/detox",
      "expo-sharing",
      "expo-updates"
    ]
  }
}
