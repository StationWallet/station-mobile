{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./src",
    "paths": {
      "components": ["./components"],
      "consts": ["./consts"],
      "types/*": ["./types/*"],
      "styles/*": ["./styles/*"],
      "utils/*": ["./utils/*"],
      "assets/*": ["./assets/*"],
      "hooks/*": ["./hooks/*"],
      "stores/*": ["./stores/*"],
      "nativeModules/*": ["./nativeModules/*"],
      "lib/*": ["./lib/*"]
    }
  },
  "include": [
    "src/**/*"
  ]
}
